{
  "rewrites": [
    {
      "source": "/((?!assets/|data/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/data/videos.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
